{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "documentTypes": [
    {
      "alias": "portfolioHome",
      "name": "Portfolio Home",
      "cultureVariant": true,
      "description": "Single-page portfolio root used by the React frontend.",
      "compositions": [
        "seoComposition",
        "heroComposition",
        "aboutComposition",
        "contactComposition",
        "sayHiComposition",
        "footerComposition"
      ]
    }
  ],
  "cultures": [
    { "isoCode": "sv-SE", "name": "Swedish", "default": true },
    { "isoCode": "en-US", "name": "English", "default": false }
  ],
  "elementTypes": [
    "heroAction",
    "systemThinkingCard",
    "skillGroup",
    "experienceItem",
    "projectItem",
    "educationItem",
    "labItem",
    "builtWithGroup",
    "contactLink"
  ],
  "invariantConstraints": {
    "heroAction.variant": ["primary", "ghost"],
    "experienceItem.sceneKey": ["dasa", "sodra", "visma", "filmstaden", "education"],
    "experienceItem.fields": [
      "id",
      "slug",
      "locale",
      "company",
      "role",
      "location",
      "employmentType",
      "startDate",
      "endDate",
      "isCurrent",
      "summary",
      "description",
      "technologies",
      "highlights",
      "sortOrder",
      "isPublished",
      "createdAt",
      "updatedAt",
      "createdBy",
      "updatedBy",
      "publishedAt",
      "version"
    ],
    "projectItem.fields": [
      "id",
      "slug",
      "locale",
      "title",
      "shortDescription",
      "description",
      "technologies",
      "repositoryUrl",
      "liveUrl",
      "imageUrl",
      "featured",
      "sortOrder",
      "isPublished",
      "createdAt",
      "updatedAt",
      "createdBy",
      "updatedBy",
      "publishedAt",
      "version"
    ],
    "educationItem.sceneKey": ["education"],
    "anchorIdPattern": "^[a-z0-9-]+$"
  },
  "forbiddenCmsFields": [
    "homeAssistantUrl",
    "homeAssistantEntityId",
    "homeAutomationWebhookId",
    "turnstileSecret",
    "accessClientSecret",
    "rateLimit",
    "cooldownSeconds"
  ]
}
