# Public frontend configuration. HSClient talks to HSApi only.
VITE_BASE_PATH=/
VITE_API_ENABLED=true
VITE_API_BASE_URL=http://localhost:5181
VITE_API_REQUEST_TIMEOUT_MS=3500
VITE_ADMIN_ENABLED=true
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Existing Say Hi frontend feature flag.
VITE_SAY_HI_ENABLED=true

# Local Umbraco install placeholders. Do not commit real values in .env files.
UMBRACO_ADMIN_EMAIL=replace-with-local-admin-email@example.com
UMBRACO_ADMIN_PASSWORD=replace-with-a-strong-local-password
UMBRACO_ADMIN_NAME=Hugo Spangberg
UMBRACO_DATABASE_DSN=Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True
UMBRACO_DATABASE_PROVIDER=Microsoft.Data.Sqlite

# HSCms configuration keys can also be provided as environment variables.
Portfolio__FrontendOrigins__0=http://localhost:5173
Portfolio__FrontendOrigins__1=http://127.0.0.1:5173
Cors__FrontendOrigins__0=http://localhost:5173
Cors__FrontendOrigins__1=http://127.0.0.1:5173
Cors__FrontendOrigins__2=http://localhost:5180
Cors__FrontendOrigins__3=http://127.0.0.1:5180
Portfolio__Seed__Enabled=true
Portfolio__Seed__Force=false
Portfolio__InternalManagementSecret=replace-with-local-shared-management-secret

# HSApi configuration placeholders. Do not commit real secrets.
ConnectionStrings__HSPortfolioApi=Server=localhost,1433;Database=HSPortfolioApi;User Id=sa;Password=replace-with-local-password;TrustServerCertificate=True
Cms__Enabled=true
Cms__BaseUrl=http://localhost:5174
Cms__ContentRoute=/portfolio
AdminAuth__Enabled=true
AdminAuth__Username=admin
AdminAuth__Password=replace-with-local-admin-password
AdminAuth__RequireSecureCookies=false
AdminAuth__CmsManagementSecret=replace-with-local-shared-management-secret
Turnstile__Enabled=false
Turnstile__SecretKey=replace-with-worker-secret
HomeAssistant__Enabled=false
HomeAssistant__WebhookUrl=https://replace-with-protected-webhook.example
HomeAssistant__AccessClientId=replace-with-access-client-id
HomeAssistant__AccessClientSecret=replace-with-access-client-secret
