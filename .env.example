# Public frontend CMS configuration. These values are safe for Vite because they
# only describe where published public content can be read.
VITE_CMS_ENABLED=false
VITE_UMBRACO_BASE_URL=http://localhost:5174
VITE_UMBRACO_CONTENT_ROUTE=/
VITE_CMS_REQUEST_TIMEOUT_MS=3500

# Existing Say Hi frontend feature flag.
VITE_SAY_HI_ENABLED=true

# Local Umbraco install placeholders. Do not commit real values in .env files.
UMBRACO_ADMIN_EMAIL=replace-with-local-admin-email@example.com
UMBRACO_ADMIN_PASSWORD=replace-with-a-strong-local-password
UMBRACO_ADMIN_NAME=Hugo Spangberg
UMBRACO_DATABASE_DSN=Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True
UMBRACO_DATABASE_PROVIDER=Microsoft.Data.Sqlite

# ASP.NET configuration keys can also be provided as environment variables.
Portfolio__FrontendOrigins__0=http://localhost:5173
Portfolio__FrontendOrigins__1=http://127.0.0.1:5173
Portfolio__Seed__Enabled=true
Portfolio__Seed__Force=false
